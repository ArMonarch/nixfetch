package nixfetch

APPRENT_WIDTH: int : 39

// builds the NixOS logo with format placeholders for system info on the right side
nix_logo_black_white :: proc() -> [dynamic]string {
	// :........................................:
	// :                                        :
	// :         ◢██◣     ◥███◣  ◢██◣           :
	// :         ◥███◣     ◥███◣◢███◤           :
	// :          ◥███◣     ◥██████◤            :
	// :      ◢███████████████████◤   ◢◣        :
	// :     ◢████████████████████◣  ◢██◣       :
	// :          ◢███◤        ◥███◣◢███◤       :
	// :         ◢███◤          ◥██████◤        :
	// :  ◢█████████◤            ◥█████████◣    :
	// :  ◥█████████◣            ◢█████████◤    :
	// :      ◢██████◣          ◢███◤           :
	// :     ◢███◤◥███◣        ◢███◤            :
	// :     ◥██◤  ◥████████████████████◤       :
	// :      ◥◤   ◢███████████████████◤        :
	// :          ◢██████◣     ◥███◣            :
	// :         ◢███◤◥███◣     ◥███◣           :
	// :         ◥██◤  ◥███◣     ◥██◤           :
	// :                                        :
	// :........................................:

	nix_logo := make_dynamic_array([dynamic]string)
	append(
		&nix_logo,
		"         ◢██◣     ◥███◣  ◢██◣          ",
		"         ◥███◣     ◥███◣◢███◤          ",
		"          ◥███◣     ◥██████◤           ",
		"      ◢███████████████████◤   ◢◣       ",
		"     ◢████████████████████◣  ◢██◣      ",
		"          ◢███◤        ◥███◣◢███◤      ",
		"         ◢███◤          ◥██████◤       ",
		"  ◢█████████◤            ◥█████████◣   ",
		"  ◥█████████◣            ◢█████████◤   ",
		"      ◢██████◣          ◢███◤          ",
		"     ◢███◤◥███◣        ◢███◤           ",
		"     ◥██◤  ◥████████████████████◤      ",
		"      ◥◤   ◢███████████████████◤       ",
		"          ◢██████◣     ◥███◣           ",
		"         ◢███◤◥███◣     ◥███◣          ",
		"         ◥██◤  ◥███◣     ◥██◤          ",
	)

	return nix_logo
}

nix_logo_ansi_colored :: proc() -> [dynamic]string {
	nix_logo := make_dynamic_array_len_cap([dynamic]string, 0, 16)
	append(
		&nix_logo,
		"  [38;2;82;119;195m       ◢██◣[38;2;127;183;255m     ◥███◣  ◢██◣          ",
		"  [38;2;82;119;195m       ◥███◣[38;2;127;183;255m     ◥███◣◢███◤          ",
		"  [38;2;82;119;195m        ◥███◣[38;2;127;183;255m     ◥██████◤           ",
		"  [38;2;82;119;195m    ◢██████████████[48;2;127;183;255m◣[0m[38;2;127;183;255m████◤[38;2;82;119;195m   ◢◣       ",
		"  [38;2;82;119;195m   ◢████████████████[48;2;127;183;255m◣[0m[38;2;127;183;255m███◣[38;2;82;119;195m  ◢██◣      ",
		"  [38;2;127;183;255m        ◢███◤        ◥███◣[38;2;82;119;195m◢███◤      ",
		"  [38;2;127;183;255m       ◢███◤          ◥██[48;2;82;119;195m◤[0m[38;2;82;119;195m███◤       ",
		"  [38;2;127;183;255m◢█████████◤            ◥[48;2;82;119;195m◤[0m[38;2;82;119;195m████████◣   ",
		"  [38;2;127;183;255m◥████████[48;2;82;119;195m◤[0m[38;2;82;119;195m◣            ◢█████████◤   ",
		"  [38;2;127;183;255m    ◢███[48;2;82;119;195m◤[0m[38;2;82;119;195m██◣          ◢███◤          ",
		"  [38;2;127;183;255m   ◢███◤[38;2;82;119;195m◥███◣        ◢███◤           ",
		"  [38;2;127;183;255m   ◥██◤  [38;2;82;119;195m◥███[48;2;127;183;255m◣[0m[38;2;127;183;255m████████████████◤      ",
		"  [38;2;127;183;255m    ◥◤   [38;2;82;119;195m◢████[48;2;127;183;255m◣[0m[38;2;127;183;255m██████████████◤       ",
		"  [38;2;82;119;195m        ◢██████◣[38;2;127;183;255m     ◥███◣           ",
		"  [38;2;82;119;195m       ◢███◤◥███◣[38;2;127;183;255m     ◥███◣          ",
		"  [38;2;82;119;195m       ◥██◤  ◥███◣[38;2;127;183;255m     ◥██◤[38;0m          ",
	)

	return nix_logo
}
